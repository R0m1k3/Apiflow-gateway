# Copier ce fichier en .env et remplir les valeurs

# Token partagé entre frps (Hostinger) et frpc (magasin)
# Doit être identique dans frps.toml ET frpc.toml côté magasin
FRP_TOKEN=CHANGE_ME_FRP_SECRET_TOKEN

# Credentials PostgreSQL Debian (source du sync)
# Même valeurs que dans foirfouille-api/.env.docker
SRC_DB=CHANGE_ME_DB_NAME
SRC_USER=CHANGE_ME_DB_USER
SRC_PASS=CHANGE_ME_DB_PASSWORD
